# ──────────────────────────────────────────────
# Rust / Cargo
# ──────────────────────────────────────────────
/target/
**/*.rs.bk
Cargo.lock

# ──────────────────────────────────────────────
# Archivos autogenerados por el PrintAgent
# ──────────────────────────────────────────────
# 1. Los logs diarios de tracing
/logs/
# 2. Los PDFs temporales que se imprimen
/temp/

# ──────────────────────────────────────────────
# Distribución y Scripts de Powershell
# ──────────────────────────────────────────────
# Evitar que se suban los .ZIP, .EXE o instaladores finales
/dist/
*.exe
*.msi
*.zip

# ──────────────────────────────────────────────
# Entornos de Desarrollo
# ──────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.sln
